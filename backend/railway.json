{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgs": ["#Inputs", "pkgs.nodejs_20", "pkgs.chromimum", "pkgs.jq"]
        },
        "install": {
          "command": "npm install"
        },
        "build": {
          "command": "npm run build"
        }
      },
      "start": {
        "command": "node dist/index.js"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
