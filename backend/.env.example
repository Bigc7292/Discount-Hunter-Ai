# Backend Environment Variables
# Copy to .env and fill in values

PORT=3001
NODE_ENV=development

# Gemini API for AI-powered discovery
GEMINI_API_KEY=

# Residential Proxy API (for geo-location testing)
# Options: Bright Data, Oxylabs, SmartProxy
RESIDENTIAL_PROXY_API_KEY=
RESIDENTIAL_PROXY_PROVIDER=brightdata

# Browser Automation
USE_HEADLESS_BROWSER=true
BROWSER_TIMEOUT_MS=30000

# Optional: Redis for caching verified codes
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info