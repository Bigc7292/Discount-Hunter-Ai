# Discount Hunter AI - Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# FRONTEND (Vite)
# ===========================================

# MiniMax API - Get from https://platform.minimax.io
VITE_MINIMAX_API_KEY=your_minimax_api_key_here
VITE_MINIMAX_API_URL=https://api.minimax.io/v1

# Verifier Backend URL
VITE_VERIFIER_API_URL=http://localhost:3001

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ===========================================
# BACKEND (Node.js)
# ===========================================

PORT=3001
NODE_ENV=development

# MiniMax API (same as frontend)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_URL=https://api.minimax.io/v1

# Residential Proxy for Geo-testing (Optional but recommended)
# Use Bright Data, Oxylabs, or SmartProxy
RESIDENTIAL_PROXY_API_KEY=
RESIDENTIAL_PROXY_PROVIDER=brightdata

# Browser Automation
USE_HEADLESS_BROWSER=true
BROWSER_TIMEOUT_MS=30000
