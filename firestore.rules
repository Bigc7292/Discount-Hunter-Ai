rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User Profiles & Inbox
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /inbox/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public Live Ticker Data – allow anyone to read recent savings
    match /recentSavings/{savingId} {
      // Unauthenticated users can read (list & get) recent savings for the ticker
      allow read: if true;
      // Only authenticated users can write new savings entries
      allow write: if request.auth != null;
    }
  }
}
